#. The warning text displayed in the main window when the program does not have a valid license. [BannerUnlicensedWarning]
#: Resources.resx
#, new
msgid "BannerUnlicensedWarning"
msgstr "Free version!"

#. The text in a button that causes an action to be canceled, i.e. "Cancel". [ButtonCancel]
#: Resources.resx
#, new
msgid "ButtonCancel"
msgstr "_Cancel"

#. A button to copy something to the clipboard [ButtonCopy]
#: Resources.resx
#, new
msgid "ButtonCopy"
msgstr "_Copy"

#. Button text for a "Copy All" button. [ButtonCopyAll]
#: Resources.resx
#, new
msgid "ButtonCopyAll"
msgstr "Copy All"

#. The text in a button to create a user, i.e. "Create". [ButtonCreate]
#: Resources.resx
#, new
msgid "ButtonCreate"
msgstr "_Create"

#. The label for the hide Premium features button. [ButtonFree]
#: Resources.resx
#, new
msgid "ButtonFree"
msgstr "Free"

#. The button prompt for windows offering to open a web browser. [ButtonGo]
#: Resources.resx
#, new
msgid "ButtonGo"
msgstr "Go!"

#. A label for a button to paste the license [ButtonLicense]
#: Resources.resx
#, new
msgid "ButtonLicense"
msgstr "License"

#. The text in a button that causes a 'No'-response, i.e. "No". [ButtonNo]
#: Resources.resx
#, new
msgid "ButtonNo"
msgstr "_No"

#. The text in a button that says 'OK', i.e. "Ok". [ButtonOk]
#: Resources.resx
#, new
msgid "ButtonOk"
msgstr "_Ok"

#. The label for the show Premium features button. [ButtonPremium]
#: Resources.resx
#, new
msgid "ButtonPremium"
msgstr "Premium"

#. A button to initiate an emergency password reset. [ButtonReset]
#: Resources.resx
#, new
msgid "ButtonReset"
msgstr "Reset!"

#. A button to retry something. [ButtonRetry]
#: Resources.resx
#, new
msgid "ButtonRetry"
msgstr "_Retry"

#. Button text for a "Save As..." button. [ButtonSaveAs]
#: Resources.resx
#, new
msgid "ButtonSaveAs"
msgstr "Save As..."

#. The text in a button that causes a 'Yes'-response, i.e. "Yes". [ButtonYes]
#: Resources.resx
#, new
msgid "ButtonYes"
msgstr "_Yes"

#. A warning shown when the discovered Cli version does not exactly match Ez. {0} is Cli version, {1} is full Cli path, {2} is Ez version. [CliVersionMismatchWarning]
#: Resources.resx
#, new
msgid "CliVersionMismatchWarning"
msgstr ""
"Warning! Version {0} of Xecrets Cli found at '{1}' does not match the version "
"{2} of Xecrets Ez. This is not recommended since it may cause "
"problems.\n"
"\n"
"Would you like to view a help page with more information?"

#. Appeneded after a statement, in a confirmation dialog. [ConfirmationQuestion]
#: Resources.resx
#, new
msgid "ConfirmationQuestion"
msgstr "Are you sure?"

#. A text in the about box, telling how many decryption passwords are known. [DecryptionPasswordsAboutFormat]
#: Resources.resx
#, new
msgid "DecryptionPasswordsAboutFormat"
msgstr "Extra decryption passwords: {0}."

#. An error message when an input value is not in the expected format. [DialogInputValidationError]
#: Resources.resx
#, new
msgid "DialogInputValidationError"
msgstr "The value is not in the correct format!"

#. A longer explanation of how to get and enter a license. {0} is replaced by the URL of the customer portal page. [DialogInstructionEnterLicenseFormat]
#: Resources.resx
#, new
msgid "DialogInstructionEnterLicenseFormat"
msgstr ""
"Copy the license key from our license page (the link looks like "
"{1}/license?s=2Rl7q1Gr…), then return here. If you already have the link, "
"open it in your browser now. Otherwise, visit {0} and follow the instructions "
"to get the correct link."

#. A label in the about box for the directory where all settings are stored. [DialogLabelAppSettingsDirectory]
#: Resources.resx
#, new
msgid "DialogLabelAppSettingsDirectory"
msgstr "Settings directory:"

#. The About Window label for the info about the current directory. [DialogLabelCurrentDirectory]
#: Resources.resx
#, new
msgid "DialogLabelCurrentDirectory"
msgstr "Current directory:"

#. A label in the about box, for the real user-visible start folder, before the OS maybe moved it. [DialogLabelRealStartFolder]
#: Resources.resx
#, new
msgid "DialogLabelRealStartFolder"
msgstr "Original start folder:"

#. The About Window label for the info about the full start command. [DialogLabelStartCommand]
#: Resources.resx
#, new
msgid "DialogLabelStartCommand"
msgstr "Start command:"

#. A text next to a check box, indicating whether an added password should be saved permanently for use, or just for this session. [DialogSavePasswordPermanently]
#: Resources.resx
#, new
msgid "DialogSavePasswordPermanently"
msgstr "Save in settings"

#. The text displayed as heading in the dialog to enter an extra alternate password. [DialogTextAddPassword]
#: Resources.resx
#, new
msgid "DialogTextAddPassword"
msgstr "Add a decryption password"

#. A text used in a file selection dialog for the file pattern '*'. [DialogTextAllFiles]
#: Resources.resx
#, new
msgid "DialogTextAllFiles"
msgstr "All files"

#. Error message for incompatible Cli API. {0} is the full path to the Cli Tool, {1} is the Cli Tool API version, {2} is the SDK API Major version, and {3} is the minor version. [DialogTextCliApiVersionError]
#: Resources.resx
#, new
msgid "DialogTextCliApiVersionError"
msgstr ""
"Incompatible Xecrets Cli found at '{0}' with API version {1}, but version "
"{2}.[>={3}] is required.\\n\\nUpdate Xecrets Cli, or remove it and use the "
"one included in the app."

#. Warning shown at startup when this executable version appears older than the most recently used version, asking whether to continue. [DialogTextDowngradedVersionWarning]
#: Resources.resx
#, new
msgid "DialogTextDowngradedVersionWarning"
msgstr ""
"You seem to have downgraded to an older version. This can happen if multiple "
"versions are installed. Do you really want to continue with this version?"

#. Text for the middle of the window, where files can be dropped or pasted. Not all OS's support drag and drop. [DialogTextDropOrPasteTitle]
#: Resources.resx
#, new
msgid "DialogTextDropOrPasteTitle"
msgstr "Drop or paste files here..."

#. The tooltip for the paste and drag and drop area, giving a little bit more information. Not all OS's support drag and drop. [DialogTextDropOrPasteToolTip]
#: Resources.resx
#, new
msgid "DialogTextDropOrPasteToolTip"
msgstr ""
"Drop or paste files here to encrypt or decrypt them. Use keyboard {0} button "
"to decrypt a single file, otherwise it opens."

#. A text used in a file selection dialog for the file pattern '*.axx'. [DialogTextEncryptedFiles]
#: Resources.resx
#, new
msgid "DialogTextEncryptedFiles"
msgstr "Encrypted files"

#. The title of the dialog to enter or paste a license string [DialogTextEnterLicense]
#: Resources.resx
#, new
msgid "DialogTextEnterLicense"
msgstr "Activate Premium license"

#. An informational message when a license is about to expire. [DialogTextExpiresSoonInfoFormat]
#: Resources.resx
#, new
msgid "DialogTextExpiresSoonInfoFormat"
msgstr ""
"Your premium license will expire on {0}. To keep using premium features, "
"please renew your license in the app after it expires."

#. An error message displayed when encrypting, decrypting or wiping could not proceed because one or more files simply were not not found and the operation is canceled. A list of files may be appended. [DialogTextFileDoesNotExist]
#: Resources.resx
#, new
msgid "DialogTextFileDoesNotExist"
msgstr "File(s) do not exist, the action was canceled."

#. An error message displayed when encrypting, decrypting or wiping could not proceed because one or more files were read-only or the user does not have sufficient permissions and the operation is canceled. A list of files may be appended. [DialogTextInsufficientRights]
#: Resources.resx
#, new
msgid "DialogTextInsufficientRights"
msgstr ""
"File(s) are read-only, the destination directory is not writeable or you do "
"not have sufficient permissions. The action was canceled."

#. Text displayed when for some unknown and unspecified reason a file was not properly decrypted and opened. [DialogTextOpenFailed]
#: Resources.resx
#, new
msgid "DialogTextOpenFailed"
msgstr "Decrypt and open failed"

#. A warning message at program exit. A new line separated list of these filesmay be appended. [DialogTextOrphanedDocumentsFiles]
#: Resources.resx
#, new
msgid "DialogTextOrphanedDocumentsFiles"
msgstr "Unrecognized temporary files remain."

#. Text for the middle of the window, where files can be (only) pasted, as some OS's don't support drag and drop. [DialogTextPasteOnlyTitle]
#: Resources.resx
#, new
msgid "DialogTextPasteOnlyTitle"
msgstr "Paste files here..."

#. The tooltip for the paste (only) area, giving a little bit more information. Not all OS's support drag and drop. [DialogTextPasteOnlyToolTip]
#: Resources.resx
#, new
msgid "DialogTextPasteOnlyToolTip"
msgstr ""
"Paste files here to encrypt or decrypt them. Use keyboard {0} to decrypt a "
"single file, otherwise it opens."

#. A pop-up message displayed after importing AxCrypt account keys. [DialogTextPrivateKeysImported]
#: Resources.resx
#, new
msgid "DialogTextPrivateKeysImported"
msgstr ""
"We found and imported account keys from AxCrypt. You may still need to "
"provide the original password a file was encrypted with if the AxCrypt "
"password was reset, changed or is different from the Xecrets Ez password."

#. A message displayed when an attempt is made to encrypt, decrypt, rename or wipe a file where sandboxing prevents creating a related sibling file. {0} is a help page URL. It may be followed by a list of affected file names only. This will abort the entire operation and nothing happens. [DialogTextRelatedAccess]
#: Resources.resx
#, new
msgid "DialogTextRelatedAccess"
msgstr ""
"File(s) require sandbox folder access to encrypt, decrypt, wipe or rename. "
"The action was canceled. See {0}."

#. A warning text when a removable drive is first used, information that all settings etc will be stored on it. [DialogTextRemovableDriveFirstWarning]
#: Resources.resx
#, new
msgid "DialogTextRemovableDriveFirstWarning"
msgstr ""
"Settings and temp files will be stored on a removable drive, not your main "
"drive. Continue?"

#. A warning text informing that a removable drive must be unplugged safely when running from it. [DialogTextRemovableDriveUnplugWarning]
#: Resources.resx
#, new
msgid "DialogTextRemovableDriveUnplugWarning"
msgstr ""
"Before unplugging it, make sure to exit the app and eject the drive safely to "
"avoid data loss."

#. A message displayed when an attempt is made to encrypt or wipe a file located in a system protected location. It may be followed by a list of affected files. This will abort the entire operation and nothing happens. [DialogTextSystemProtected]
#: Resources.resx
#, new
msgid "DialogTextSystemProtected"
msgstr "File(s) are system protected, the action was canceled."

#. Informing that one or more files could not be encrypted due to licensing restrictions. A list of files may be appended. [DialogTextTooLargeForLicense]
#: Resources.resx
#, new
msgid "DialogTextTooLargeForLicense"
msgstr "File(s) were not encrypted. Encryption limit is 1 MB. See About."

#. The text shown when a decryption fails because of unknown password. [DialogTextUnknownPassword]
#: Resources.resx
#, new
msgid "DialogTextUnknownPassword"
msgstr "File(s) could not be decrypted. Try adding an alternative password."

#. Text displayed when an attempt to open a file for editing fails due to wrong password, hinting that perhaps it has to be decrypted first using an alternative password. [DialogTextWrongPasswordOpen]
#: Resources.resx
#, new
msgid "DialogTextWrongPasswordOpen"
msgstr ""
"The file could not be opened. Try decrypting with an alternative password "
"first."

#. Dialog title of the dialog where a user can request a purchased license using an email and the last 4 digits of the card used. [DialogTitleFetchLicense]
#: Resources.resx
#, new
msgid "DialogTitleFetchLicense"
msgstr "Get subscription license"

#. A title for dialogs warning about the situation where we're running from a removable drive. [DialogTitleRemovableDrive]
#: Resources.resx
#, new
msgid "DialogTitleRemovableDrive"
msgstr "Running from removable drive!"

#. The dialog title when selecting a destination folder. [DialogTitleSelectDestinationFolder]
#: Resources.resx
#, new
msgid "DialogTitleSelectDestinationFolder"
msgstr "Select destination folder"

#. The title of a file selection dialog for selecting a file to open, i.e. 'Select files to open'. [DialogTitleSelectFileToOpen]
#: Resources.resx
#, new
msgid "DialogTitleSelectFileToOpen"
msgstr "Select file to open"

#. The title of a file selection dialog for selecting files to decrypt, i.e. 'Select files to decrypt'. [DialogTitleSelectFilesToDecrypt]
#: Resources.resx
#, new
msgid "DialogTitleSelectFilesToDecrypt"
msgstr "Select files to decrypt"

#. The title of a file selection dialog for selecting files to encrypt, i.e. 'Select files to encrypt'. [DialogTitleSelectFilesToEncrypt]
#: Resources.resx
#, new
msgid "DialogTitleSelectFilesToEncrypt"
msgstr "Select files to encrypt"

#. This is the title for the open dialog to select files to re-encrypt [DialogTitleSelectFilesToReEncrypt]
#: Resources.resx
#, new
msgid "DialogTitleSelectFilesToReEncrypt"
msgstr "Select files to re-encrypt"

#. The title of a file selection dialog for selecting files to wipe, i.e. 'Select files to wipe'. [DialogTitleSelectFilesToWipe]
#: Resources.resx
#, new
msgid "DialogTitleSelectFilesToWipe"
msgstr "Select files to wipe"

#. A title for a generic select folder picker, used for both encrypt and decrypt folder etc. [DialogTitleSelectFolder]
#: Resources.resx
#, new
msgid "DialogTitleSelectFolder"
msgstr "Select folder"

#. An error text displayed when an attempt is made to sign in twice with the same profile email. [DialogValidationAlreadySignedIn]
#: Resources.resx
#, new
msgid "DialogValidationAlreadySignedIn"
msgstr ""
"You are already signed in. Look for the app behind another window, on another "
"screen, among minimized apps or in the system tray and show the window from "
"there."

#. An error text displayed when no password confirmation was entered. [DialogValidationConfirmPassword]
#: Resources.resx
#, new
msgid "DialogValidationConfirmPassword"
msgstr "Please confirm the password again"

#. An error text displayed when validation of email format fails. [DialogValidationInvalidEmail]
#: Resources.resx
#, new
msgid "DialogValidationInvalidEmail"
msgstr "Please enter a valid email address"

#. An error text displayed when no password is entered although required. [DialogValidationPasswordRequired]
#: Resources.resx
#, new
msgid "DialogValidationPasswordRequired"
msgstr "Please enter a password"

#. An error message displayed in a dialog when the users enters the wrong password. [DialogValidationWrongPassword]
#: Resources.resx
#, new
msgid "DialogValidationWrongPassword"
msgstr "Wrong password!"

#. An information message giving a hint that to change the configuration, you first need to remove the current configuration. [DialogYubiKeyChangeConfiguration]
#: Resources.resx
#, new
msgid "DialogYubiKeyChangeConfiguration"
msgstr ""
"To change the YubiKey configuration, you must first remove the existing "
"configuration."

#. An information message giving hints on how to change YubiKey defaults, and referring to help for more info where actual links etc are. [DialogYubiKeyDefaultChangeInfo]
#: Resources.resx
#, new
msgid "DialogYubiKeyDefaultChangeInfo"
msgstr ""
"To change the PIN, PUK, or Management Key, get the Yubico Authenticator app "
"and go to Certificates settings. For details, click the help icon."

#. Dialog title for the YubiKey disabling setup dialog. [DialogYubiKeyDisable]
#: Resources.resx
#, new
msgid "DialogYubiKeyDisable"
msgstr "Do you want to remove the YubiKey configuration?"

#. Dialog title for the YubiKey enabling setup dialog. [DialogYubiKeyEnable]
#: Resources.resx
#, new
msgid "DialogYubiKeyEnable"
msgstr "Do you want to enable this YubiKey for signing in?"

#. Error message when enabling fails, typically because there are no slots. [DialogYubiKeyEnabledFailed]
#: Resources.resx
#, new
msgid "DialogYubiKeyEnabledFailed"
msgstr ""
"It is not possible to use this YubiKey. There may not be any slots available."

#. A dialog title used when asking for PIV management key authentication [DialogYubiKeyEnterKeyTitle]
#: Resources.resx
#, new
msgid "DialogYubiKeyEnterKeyTitle"
msgstr "Please enter YubiKey PIV hex management key:"

#. A dialog title used when asking for the PIN [DialogYubiKeyEnterPinTitle]
#: Resources.resx
#, new
msgid "DialogYubiKeyEnterPinTitle"
msgstr "Please enter YubiKey PIV PIN:"

#. Dialog title displayed when we're checking for a YubiKey during setup [DialogYubiKeyLooking]
#: Resources.resx
#, new
msgid "DialogYubiKeyLooking"
msgstr "Waiting for YubiKey..."

#. A warning message stating that the PIV management key still has it's default value. [DialogYubiKeyManagementKeyDefault]
#: Resources.resx
#, new
msgid "DialogYubiKeyManagementKeyDefault"
msgstr ""
"The PIV management key has it's default value 3 x 0102030405060708, it should "
"be changed!"

#. An error message displayed when a non-conforming YubiKey is connected. [DialogYubiKeyMissingFeatures]
#: Resources.resx
#, new
msgid "DialogYubiKeyMissingFeatures"
msgstr "Required features are missing from this YubiKey."

#. Dialog title for the YubiKey setup dialog when there is no yubikey connected and no configuration. [DialogYubiKeyNotConnected]
#: Resources.resx
#, new
msgid "DialogYubiKeyNotConnected"
msgstr "There is no YubiKey connected!"

#. An informational message displayed when the connected YubiKey is not initialized. [DialogYubiKeyNotInitialized]
#: Resources.resx
#, new
msgid "DialogYubiKeyNotInitialized"
msgstr "This YubiKey is not yet initialized for use."

#. A title dialog text displayed when a YubiKey is detected, but it doesn't have sufficient capabilities. [DialogYubiKeyNotSupported]
#: Resources.resx
#, new
msgid "DialogYubiKeyNotSupported"
msgstr "This YubiKey is not supported!"

#. An info message stating that it's enough to touch the YubiKey to sign in. [DialogYubiKeyOnlyTouch]
#: Resources.resx
#, new
msgid "DialogYubiKeyOnlyTouch"
msgstr "Only this YubiKey and a touch is required to sign in."

#. A description of how the Open security mode works. [DialogYubiKeyOpenSecurity]
#: Resources.resx
#, new
msgid "DialogYubiKeyOpenSecurity"
msgstr "Only this YubiKey is required to sign in."

#. [DialogYubiKeyPcscMissing]
#: Resources.resx
#, new
msgid "DialogYubiKeyPcscMissing"
msgstr ""
"Please ensure that pcscd / pcsc-lite is installed and the daemon is running. "
"Click the help icon for more information about YubiKey and Linux."

#. A warning message saying that the PIV PIN still has it's default value. [DialogYubiKeyPinDefault]
#: Resources.resx
#, new
msgid "DialogYubiKeyPinDefault"
msgstr "The PIV PIN has it's default value 123456, it should be changed!"

#. An info message stating that the PIN is required to sign in. [DialogYubiKeyPinRequired]
#: Resources.resx
#, new
msgid "DialogYubiKeyPinRequired"
msgstr "This YubiKey and the PIN is required to sign in."

#. An informational message displayed about what slot will be used. '{0}' will be filled with the actual slot in question. [DialogYubiKeyPivSlotUsedFormat]
#: Resources.resx
#, new
msgid "DialogYubiKeyPivSlotUsedFormat"
msgstr "PIV slot {0} is currently used or possible to use."

#. A warning message stating that the PIV PUK still has it's default value. [DialogYubiKeyPukDefault]
#: Resources.resx
#, new
msgid "DialogYubiKeyPukDefault"
msgstr "The PIV PUK has it's default value 12345678, it should be changed!"

#. A warning message stating that the VC++ redistributable is missing, and providing a link to download it. [DialogYubiKeyRedistributableMissing]
#: Resources.resx
#, new
msgid "DialogYubiKeyRedistributableMissing"
msgstr ""
"To use YubiKey, the Microsoft Visual C++ Redistributable must be installed. "
"Download it from {0}, run the installer, and restart the application."

#. A sub-title in the dialog above a list of radio buttons where a choice of the security mode is made. [DialogYubiKeySelectMode]
#: Resources.resx
#, new
msgid "DialogYubiKeySelectMode"
msgstr "Select how you want to use your YubiKey."

#. [DialogYubiKeyServiceUnsupported]
#: Resources.resx
#, new
msgid "DialogYubiKeyServiceUnsupported"
msgstr "This app can’t use a YubiKey on this operating system."

#. A modal disappearing prompt to touch the YubiKey when required. [DialogYubiKeyTouchPrompt]
#: Resources.resx
#, new
msgid "DialogYubiKeyTouchPrompt"
msgstr "Please touch the YubiKey..."

#. Label for a checkbox to optionally hide a specific warning or other message. [DontShowAgain]
#: Resources.resx
#, new
msgid "DontShowAgain"
msgstr "Don't show this again"

#. A dialog box text, asking the user if (s)he wants to download a free premium trial license. [DownloadFreeTrialQuestion]
#: Resources.resx
#, new
msgid "DownloadFreeTrialQuestion"
msgstr "Would you like to try premium free for 3 days? No credit card required."

#. An error text when shares can't be combined either because they are mismatched, or in the wrong format. [ErrorCombiningShares]
#: Resources.resx
#, new
msgid "ErrorCombiningShares"
msgstr ""
"The shares could not be combined. Please check the shares and try again."

#. An error text when duplicate shares were entered and removed. [ErrorDuplicatesRemoved]
#: Resources.resx
#, new
msgid "ErrorDuplicatesRemoved"
msgstr "Duplicate shares were removed."

#. A warning message displayed when a free, non-purchased, license has expired. [ExpirationCheckPurchaseWarning]
#: Resources.resx
#, new
msgid "ExpirationCheckPurchaseWarning"
msgstr ""
"Your free trial license has expired. Do you want to view the subscription "
"information web page?"

#. The text in a message box informing the user that the license is expired, and asking if the user wants to download an update. [ExpirationCheckWarning]
#: Resources.resx
#, new
msgid "ExpirationCheckWarning"
msgstr "Your license has expired. Do you want to download an updated license?"

#. The question asked when an attempt is made to use a premium feature in the free version. [FeatureNotFreeHideQuestion]
#: Resources.resx
#, new
msgid "FeatureNotFreeHideQuestion"
msgstr "Do you want to hide all premium features?"

#. The info text show when the user attempts to use a non-free feature. [FeatureNotFreeInformation]
#: Resources.resx
#, new
msgid "FeatureNotFreeInformation"
msgstr ""
"Standard encryption and decryption is of course always free!\n"
"\n"
"If you like the program and would like to enable all features, please "
"support\n"
"us by purchasing a subscription at {0}.\n"
"\n"
"It's not free, but it's not expensive either and totally worth it we think!"

#. The first short text specifying a feature is not free. [FeatureNotFreeShortInformation]
#: Resources.resx
#, new
msgid "FeatureNotFreeShortInformation"
msgstr "Sorry, this premium feature is not available in the free version."

#. The title of the text box to show when the user attempts to use a non-free feature. {0} is the program name, and should always be first in all translations. [FeatureNotFreeTitle]
#: Resources.resx
#, new
msgid "FeatureNotFreeTitle"
msgstr "{0} Feature not available"

#. A message displayed as user feedback when an operation was canceled. [FilesCanceledMessage]
#: Resources.resx
#, new
msgid "FilesCanceledMessage"
msgstr "Canceled"

#. The progress finished indicator. The {0} is replaced by the number of files, 0, 1 or many. [FilesProcessedMessageFormat]
#: Resources.resx
#, new
msgid "FilesProcessedMessageFormat"
msgstr "No files|{0} file|{0} files"

#. A tooltip text explaining how getting the license works. [GetLicenseTooltip]
#: Resources.resx
#, new
msgid "GetLicenseTooltip"
msgstr ""
"A browser window will open. Copy the license from there, return here and "
"paste it."

#. A heading in the create new user window, i.e. "Create New User". [HeadingCreateNewUser]
#: Resources.resx
#, new
msgid "HeadingCreateNewUser"
msgstr "Create new profile"

#. A heading in the create user window, i.e. "First Time Setup". [HeadingCreateUserFirstTimeSetup]
#: Resources.resx
#, new
msgid "HeadingCreateUserFirstTimeSetup"
msgstr "Setup a local profile"

#. The heading for the emergency reset password dialog [HeadingEmergencyReset]
#: Resources.resx
#, new
msgid "HeadingEmergencyReset"
msgstr "Reset password!"

#. A text used to issue a warning to the user that an attempt was made to add an invalid or expired license. [InvalidLicenseIgnored]
#: Resources.resx
#, new
msgid "InvalidLicenseIgnored"
msgstr "License is invalid or expired."

#. The text label describing the action for the clear passwords dialog. The {0} will be replaced by a number. This is a plural text, the first is for zero, then one, and then 2 or more separated by '|'. [LabelDecryptionPasswordCountFormat]
#: Resources.resx
#, new
msgid "LabelDecryptionPasswordCountFormat"
msgstr ""
"There are no saved passwords to clear.|There is one saved password. Clear "
"it?|There are {0} passwords saved. Clear them all?"

#. A label displayed for the last 4 digits input field. [LabelLast4]
#: Resources.resx
#, new
msgid "LabelLast4"
msgstr "Last 4 digits of credit card, or empty."

#. A label for the textbox where a recovered secret is displayed. [LabelTheSecret]
#: Resources.resx
#, new
msgid "LabelTheSecret"
msgstr "The secret"

#. A text fragment appearing in the about window, informing that the license is not valid for Ez. [LicenseNotValidForProductBlurb]
#: Resources.resx
#, new
msgid "LicenseNotValidForProductBlurb"
msgstr ""
"License '{product}' for {licensee} is not valid for this software. Free "
"version, some features unavailable.\\nSee https://www.axantum.com/ ."

#. A text fragment appearing in the about window, informing that there is a currently valid license. [LicensedBlurb]
#: Resources.resx
#, new
msgid "LicensedBlurb"
msgstr "License for {licensee} valid to {expiration}, thank you!"

#. A text fragment appearing in the about window, informing that there is a previously valid license, now expired. [LicensedExpiredBlurb]
#: Resources.resx
#, new
msgid "LicensedExpiredBlurb"
msgstr ""
"License for {licensee} expired at {expiration}.\\nFree version, some features "
"unavailable.\\nSee https://www.axantum.com/ ."

#. The text in the menu to open a window with about information, i.e. "About". (_ indicates keyboard accelerator) [MenuAbout]
#: Resources.resx
#, new
msgid "MenuAbout"
msgstr "_About"

#. The menu item under to add an extra alternate password. [MenuAddPassword]
#: Resources.resx
#, new
msgid "MenuAddPassword"
msgstr "_Add decryption password..."

#. The menu text for a link to the purchase page. [MenuBuyNow]
#: Resources.resx
#, new
msgid "MenuBuyNow"
msgstr "Subscribe to _premium..."

#. The text used as a title in the change email dialog and the menu [MenuChangeEmail]
#: Resources.resx
#, new
msgid "MenuChangeEmail"
msgstr "Change _email..."

#. The text in the menu to open a dialog to change the password, i.e. "Change _Password...". (_ indicates keyboard accelerator) [MenuChangePassword]
#: Resources.resx
#, new
msgid "MenuChangePassword"
msgstr "Change _password..."

#. A menu entry to clear previously hidden warnings [MenuClearDontShowAgain]
#: Resources.resx
#, new
msgid "MenuClearDontShowAgain"
msgstr "Show all _messages again"

#. Menu title for the clear passwords function. Also used as the title of the dialog, edited to remove "..." and accelerators [MenuClearPasswords]
#: Resources.resx
#, new
msgid "MenuClearPasswords"
msgstr "_Clear decryption passwords..."

#. The  menu item to clear the recent files list [MenuClearRecent]
#: Resources.resx
