#. The warning text displayed in the main window when the program does not have a valid license. [BannerUnlicensedWarning]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c2
#| msgid "Free version!"
msgid "BannerUnlicensedWarning"
msgstr "Versão gratuita!"

#. The text in a button that causes an action to be canceled, i.e. "Cancel". [ButtonCancel]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c3
#| msgid "_Cancel"
msgid "ButtonCancel"
msgstr "_Cancelar"

#. A button to copy something to the clipboard [ButtonCopy]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c4
#| msgid "_Copy"
msgid "ButtonCopy"
msgstr "_Copiar"

#. Button text for a "Copy All" button. [ButtonCopyAll]
#: Resources.resx loco:68396d06ff6b3f753f0e72d2
#| msgid "Copy All"
msgid "ButtonCopyAll"
msgstr "Copiar Tudo"

#. The text in a button to create a user, i.e. "Create". [ButtonCreate]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c5
#| msgid "_Create"
msgid "ButtonCreate"
msgstr "_Criar"

#. The label for the hide Premium features button. [ButtonFree]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c6
#| msgid "Free"
msgid "ButtonFree"
msgstr "Grátis"

#. The button prompt for windows offering to open a web browser. [ButtonGo]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c7
#| msgid "Go!"
msgid "ButtonGo"
msgstr "Prosseguir!"

#. A label for a button to paste the license [ButtonLicense]
#: Resources.resx loco:6745a304c4fd5b3bae0bcef2
#| msgid "License"
msgid "ButtonLicense"
msgstr "Licença"

#. The text in a button that causes a 'No'-response, i.e. "No". [ButtonNo]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c8
#| msgid "_No"
msgid "ButtonNo"
msgstr "_Não"

#. The text in a button that says 'OK', i.e. "Ok". [ButtonOk]
#: Resources.resx loco:670e1cf615d80a27bc0eb3c9
#| msgid "_Ok"
msgid "ButtonOk"
msgstr "_Ok"

#. The label for the show Premium features button. [ButtonPremium]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ca
#| msgid "Premium"
msgid "ButtonPremium"
msgstr "Premium"

#. A button to initiate an emergency password reset. [ButtonReset]
#: Resources.resx loco:670e1cf615d80a27bc0eb3cb
#| msgid "Reset!"
msgid "ButtonReset"
msgstr "Redefinir"

#. A button to retry something. [ButtonRetry]
#: Resources.resx loco:670e1cf615d80a27bc0eb3cc
#| msgid "_Retry"
msgid "ButtonRetry"
msgstr "_Repetir"

#. Button text for a "Save As..." button. [ButtonSaveAs]
#: Resources.resx loco:68396d06ff6b3f753f0e72d3
#| msgid "Save As..."
msgid "ButtonSaveAs"
msgstr "Salvar Como..."

#. The text in a button that causes a 'Yes'-response, i.e. "Yes". [ButtonYes]
#: Resources.resx loco:670e1cf615d80a27bc0eb3cd
#| msgid "_Yes"
msgid "ButtonYes"
msgstr "_Sim"

#. A warning shown when the discovered Cli version does not exactly match Ez. {0} is Cli version, {1} is full Cli path, {2} is Ez version. [CliVersionMismatchWarning]
#: Resources.resx loco:69f7310c4779aa23dc088c42
#, icu-format
#| msgid ""
#| "Warning! Version {0} of Xecrets Cli found at '{1}' does not match the "
#| "version {2} of Xecrets Ez. This is not recommended since it may cause "
#| "problems.\n"
#| "\n"
#| "Would you like to view a help page with more information?"
msgid "CliVersionMismatchWarning"
msgstr ""
"Aviso! A versão {0} do Xecrets Cli encontrada em '{1}' não corresponde à "
"versão {2} do Xecrets Ez. Isso não é recomendado, pois pode causar problemas."
"\n"
"\n"
"Deseja abrir uma página de ajuda com mais informações?"

#. Appeneded after a statement, in a confirmation dialog. [ConfirmationQuestion]
#: Resources.resx loco:67572ea92257d74f5c003652
#| msgid "Are you sure?"
msgid "ConfirmationQuestion"
msgstr "Tem certeza?"

#. A text in the about box, telling how many decryption passwords are known. [DecryptionPasswordsAboutFormat]
#: Resources.resx loco:6745a304c4fd5b3bae0bcef3
#, icu-format
#| msgid "Extra decryption passwords: {0}."
msgid "DecryptionPasswordsAboutFormat"
msgstr "Senhas extras de descriptografia: {0}."

#. An error message when an input value is not in the expected format. [DialogInputValidationError]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ce
#| msgid "The value is not in the correct format!"
msgid "DialogInputValidationError"
msgstr "O valor não está no formato correto!"

#. A longer explanation of how to get and enter a license. {0} is replaced by the URL of the customer portal page. [DialogInstructionEnterLicenseFormat]
#: Resources.resx loco:68c58fbe8a59c0d4460a2602
#, icu-format
#| msgid ""
#| "Copy the license key from our license page (the link looks like {1}"
#| "/license?s=2Rl7q1Gr…), then return here. If you already have the link, "
#| "open it in your browser now. Otherwise, visit {0} and follow the "
#| "instructions to get the correct link."
msgid "DialogInstructionEnterLicenseFormat"
msgstr ""
"Copie a chave de licença da nossa página de licença (o link é parecido com "
"{1}/license?s=2Rl7q1Gr…), depois volte aqui. Se você já tiver o link, abra-o "
"agora no navegador. Caso contrário, visite {0} e siga as instruções para "
"obter o link correto."

#. A label in the about box for the directory where all settings are stored. [DialogLabelAppSettingsDirectory]
#: Resources.resx loco:670e1cf615d80a27bc0eb3cf
#| msgid "Settings directory:"
msgid "DialogLabelAppSettingsDirectory"
msgstr "Diretório de configurações:"

#. The About Window label for the info about the current directory. [DialogLabelCurrentDirectory]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d0
#| msgid "Current directory:"
msgid "DialogLabelCurrentDirectory"
msgstr "Diretório atual:"

#. A label in the about box, for the real user-visible start folder, before the OS maybe moved it. [DialogLabelRealStartFolder]
#: Resources.resx loco:682199e78d3ada6cc1059402
#| msgid "Original start folder:"
msgid "DialogLabelRealStartFolder"
msgstr "Pasta inicial original:"

#. The About Window label for the info about the full start command. [DialogLabelStartCommand]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d1
#| msgid "Start command:"
msgid "DialogLabelStartCommand"
msgstr "Comando de inicialização:"

#. A text next to a check box, indicating whether an added password should be saved permanently for use, or just for this session. [DialogSavePasswordPermanently]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d2
#| msgid "Save in settings"
msgid "DialogSavePasswordPermanently"
msgstr "Salvar nas configurações"

#. The text displayed as heading in the dialog to enter an extra alternate password. [DialogTextAddPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d3
#| msgid "Add a decryption password"
msgid "DialogTextAddPassword"
msgstr "Adicionar uma senha de descriptografia"

#. A text used in a file selection dialog for the file pattern '*'. [DialogTextAllFiles]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d4
#| msgid "All files"
msgid "DialogTextAllFiles"
msgstr "Todos os arquivos"

#. Error message for incompatible Cli API. {0} is the full path to the Cli Tool, {1} is the Cli Tool API version, {2} is the SDK API Major version, and {3} is the minor version. [DialogTextCliApiVersionError]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d5
#, icu-format
#| msgid ""
#| "Incompatible Xecrets Cli found at '{0}' with API version {1}, but version "
#| "{2}.[>={3}] is required.\\n\\nUpdate Xecrets Cli, or remove it and use "
#| "the one included in the app."
msgid "DialogTextCliApiVersionError"
msgstr ""
"Foi encontrado um Xecrets Cli incompatível em '{0}' com a versão da API {1}, "
"mas é necessária a versão {2}.[>={3}].\\n\\nAtualize o Xecrets Cli ou remova-"
"o e utilize a versão incluída no aplicativo."

#. Warning shown at startup when this executable version appears older than the most recently used version, asking whether to continue. [DialogTextDowngradedVersionWarning]
#: Resources.resx loco:6a11e94a21b5c894ec094902
#| msgid ""
#| "You seem to have downgraded to an older version. This can happen if "
#| "multiple versions are installed. Do you really want to continue with this "
#| "version?"
msgid "DialogTextDowngradedVersionWarning"
msgstr ""
"Parece que você reverteu para uma versão mais antiga. Isso pode acontecer se "
"várias versões estiverem instaladas. Tem certeza de que deseja continuar com "
"esta versão?"

#. Text for the middle of the window, where files can be dropped or pasted. Not all OS's support drag and drop. [DialogTextDropOrPasteTitle]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d6
#| msgid "Drop or paste files here..."
msgid "DialogTextDropOrPasteTitle"
msgstr "Arraste ou cole arquivos aqui..."

#. The tooltip for the paste and drag and drop area, giving a little bit more information. Not all OS's support drag and drop. [DialogTextDropOrPasteToolTip]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d7
#, icu-format
#| msgid ""
#| "Drop or paste files here to encrypt or decrypt them. Use keyboard {0} "
#| "button to decrypt a single file, otherwise it opens."
msgid "DialogTextDropOrPasteToolTip"
msgstr ""
"Arraste ou cole arquivos aqui para criptografar ou descriptografar. Use a "
"tecla {0} para descriptografar um único arquivo, caso contrário ele será "
"aberto."

#. A text used in a file selection dialog for the file pattern '*.axx'. [DialogTextEncryptedFiles]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d8
#| msgid "Encrypted files"
msgid "DialogTextEncryptedFiles"
msgstr "Arquivos criptografados"

#. The title of the dialog to enter or paste a license string [DialogTextEnterLicense]
#: Resources.resx loco:68c58fbe8a59c0d4460a2603
#| msgid "Activate Premium license"
msgid "DialogTextEnterLicense"
msgstr "Ativar licença Premium"

#. An informational message when a license is about to expire. [DialogTextExpiresSoonInfoFormat]
#: Resources.resx loco:6822e2b30e5cfb56550bc502
#, icu-format
#| msgid ""
#| "Your premium license will expire on {0}. To keep using premium features, "
#| "please renew your license in the app after it expires."
msgid "DialogTextExpiresSoonInfoFormat"
msgstr ""
"Sua licença premium expirará em {0}. Para continuar usando os recursos "
"premium, renove sua licença no aplicativo após a expiração."

#. An error message displayed when encrypting, decrypting or wiping could not proceed because one or more files simply were not not found and the operation is canceled. A list of files may be appended. [DialogTextFileDoesNotExist]
#: Resources.resx loco:670e1cf615d80a27bc0eb3d9
#| msgid "File(s) do not exist, the action was canceled."
msgid "DialogTextFileDoesNotExist"
msgstr "Arquivo(s) não existem, a ação foi cancelada."

#. An error message displayed when encrypting, decrypting or wiping could not proceed because one or more files were read-only or the user does not have sufficient permissions and the operation is canceled. A list of files may be appended. [DialogTextInsufficientRights]
#: Resources.resx loco:670e1cf615d80a27bc0eb3da
#| msgid ""
#| "File(s) are read-only, the destination directory is not writeable or you "
#| "do not have sufficient permissions. The action was canceled."
msgid "DialogTextInsufficientRights"
msgstr ""
"O(s) arquivo(s) são somente leitura, o diretório de destino não é gravável "
"ou você não tem permissões suficientes. A ação foi cancelada."

#. Text displayed when for some unknown and unspecified reason a file was not properly decrypted and opened. [DialogTextOpenFailed]
#: Resources.resx loco:670e1cf615d80a27bc0eb3db
#| msgid "Decrypt and open failed"
msgid "DialogTextOpenFailed"
msgstr "Falha ao descriptograr e abrir"

#. A warning message at program exit. A new line separated list of these filesmay be appended. [DialogTextOrphanedDocumentsFiles]
#: Resources.resx loco:670e1cf615d80a27bc0eb3dc
#| msgid "Unrecognized temporary files remain."
msgid "DialogTextOrphanedDocumentsFiles"
msgstr "Arquivos temporários não reconhecidos permanecem."

#. Text for the middle of the window, where files can be (only) pasted, as some OS's don't support drag and drop. [DialogTextPasteOnlyTitle]
#: Resources.resx loco:670e1cf615d80a27bc0eb3dd
#| msgid "Paste files here..."
msgid "DialogTextPasteOnlyTitle"
msgstr "Cole arquivos aqui..."

#. The tooltip for the paste (only) area, giving a little bit more information. Not all OS's support drag and drop. [DialogTextPasteOnlyToolTip]
#: Resources.resx loco:670e1cf615d80a27bc0eb3de
#, icu-format
#| msgid ""
#| "Paste files here to encrypt or decrypt them. Use keyboard {0} to decrypt "
#| "a single file, otherwise it opens."
msgid "DialogTextPasteOnlyToolTip"
msgstr ""
"Cole arquivos aqui para criptografar ou descriptografar. Use a tecla {0} "
"para descriptografar um único arquivo, caso contrário ele será aberto."

#. A pop-up message displayed after importing AxCrypt account keys. [DialogTextPrivateKeysImported]
#: Resources.resx loco:6745a304c4fd5b3bae0bcef4
#| msgid ""
#| "We found and imported account keys from AxCrypt. You may still need to "
#| "provide the original password a file was encrypted with if the AxCrypt "
#| "password was reset, changed or is different from the Xecrets Ez password."
msgid "DialogTextPrivateKeysImported"
msgstr ""
"Encontramos e importamos chaves de conta do AxCrypt. Você ainda pode "
"precisar fornecer a senha original com a qual o arquivo foi criptografado, "
"caso a senha do AxCrypt tenha sido redefinida, alterada ou seja diferente da "
"senha do Xecrets Ez."

#. A message displayed when an attempt is made to encrypt, decrypt, rename or wipe a file where sandboxing prevents creating a related sibling file. {0} is a help page URL. It may be followed by a list of affected file names only. This will abort the entire operation and nothing happens. [DialogTextRelatedAccess]
#: Resources.resx loco:6a2591b58d8a3eb6db0f80b2
#, icu-format
#| msgid ""
#| "File(s) require sandbox folder access to encrypt, decrypt, wipe or rename."
#| " The action was canceled. See {0}."
msgid "DialogTextRelatedAccess"
msgstr ""
"O(s) arquivo(s) requer(em) acesso à pasta de sandbox para criptografar, "
"descriptografar, apagar com segurança ou renomear. A ação foi cancelada. "
"Consulte {0}."

#. A warning text when a removable drive is first used, information that all settings etc will be stored on it. [DialogTextRemovableDriveFirstWarning]
#: Resources.resx loco:681f897716bfcd2acb006662
#| msgid ""
#| "Settings and temp files will be stored on a removable drive, not your "
#| "main drive. Continue?"
msgid "DialogTextRemovableDriveFirstWarning"
msgstr ""
"As configurações e os arquivos temporários serão armazenados em uma unidade "
"removível, e não na unidade principal. Deseja continuar?"

#. A warning text informing that a removable drive must be unplugged safely when running from it. [DialogTextRemovableDriveUnplugWarning]
#: Resources.resx loco:681f897716bfcd2acb006663
#| msgid ""
#| "Before unplugging it, make sure to exit the app and eject the drive "
#| "safely to avoid data loss."
msgid "DialogTextRemovableDriveUnplugWarning"
msgstr ""
"Antes de desconectá-la, certifique-se de sair do aplicativo e ejetar a "
"unidade com segurança para evitar a perda de dados."

#. A message displayed when an attempt is made to encrypt or wipe a file located in a system protected location. It may be followed by a list of affected files. This will abort the entire operation and nothing happens. [DialogTextSystemProtected]
#: Resources.resx loco:670e1cf615d80a27bc0eb3df
#| msgid "File(s) are system protected, the action was canceled."
msgid "DialogTextSystemProtected"
msgstr "Arquivo(s) protegido(s) pelo sistema, a ação foi cancelada."

#. Informing that one or more files could not be encrypted due to licensing restrictions. A list of files may be appended. [DialogTextTooLargeForLicense]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e0
#| msgid "File(s) were not encrypted. Encryption limit is 1 MB. See About."
msgid "DialogTextTooLargeForLicense"
msgstr ""
"Arquivo(s) não foram criptografados. O limite de criptografia é 1 MB. Veja "
"Sobre."

#. The text shown when a decryption fails because of unknown password. [DialogTextUnknownPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e1
#| msgid "File(s) could not be decrypted. Try adding an alternative password."
msgid "DialogTextUnknownPassword"
msgstr ""
"Arquivo(s) não puderam ser descriptografados. Tente adicionar uma senha "
"alternativa."

#. Text displayed when an attempt to open a file for editing fails due to wrong password, hinting that perhaps it has to be decrypted first using an alternative password. [DialogTextWrongPasswordOpen]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e2
#| msgid ""
#| "The file could not be opened. Try decrypting with an alternative password "
#| "first."
msgid "DialogTextWrongPasswordOpen"
msgstr ""
"O arquivo não pôde ser aberto. Tente descriptografar primeiro com uma senha "
"alternativa."

#. Dialog title of the dialog where a user can request a purchased license using an email and the last 4 digits of the card used. [DialogTitleFetchLicense]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e3
#| msgid "Get subscription license"
msgid "DialogTitleFetchLicense"
msgstr "Obter licença da assinatura"

#. A title for dialogs warning about the situation where we're running from a removable drive. [DialogTitleRemovableDrive]
#: Resources.resx loco:681f897716bfcd2acb006664
#| msgid "Running from removable drive!"
msgid "DialogTitleRemovableDrive"
msgstr "Executando a partir de unidade removível!"

#. The dialog title when selecting a destination folder. [DialogTitleSelectDestinationFolder]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e4
#| msgid "Select destination folder"
msgid "DialogTitleSelectDestinationFolder"
msgstr "Selecionar pasta de destino"

#. The title of a file selection dialog for selecting a file to open, i.e. 'Select files to open'. [DialogTitleSelectFileToOpen]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e5
#| msgid "Select file to open"
msgid "DialogTitleSelectFileToOpen"
msgstr "Selecionar arquivo para abrir"

#. The title of a file selection dialog for selecting files to decrypt, i.e. 'Select files to decrypt'. [DialogTitleSelectFilesToDecrypt]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e6
#| msgid "Select files to decrypt"
msgid "DialogTitleSelectFilesToDecrypt"
msgstr "Selecionar arquivos para descriptografar"

#. The title of a file selection dialog for selecting files to encrypt, i.e. 'Select files to encrypt'. [DialogTitleSelectFilesToEncrypt]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e7
#| msgid "Select files to encrypt"
msgid "DialogTitleSelectFilesToEncrypt"
msgstr "Selecionar arquivos para criptografar"

#. This is the title for the open dialog to select files to re-encrypt [DialogTitleSelectFilesToReEncrypt]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e8
#| msgid "Select files to re-encrypt"
msgid "DialogTitleSelectFilesToReEncrypt"
msgstr "Selecione os arquivos para recriptografar"

#. The title of a file selection dialog for selecting files to wipe, i.e. 'Select files to wipe'. [DialogTitleSelectFilesToWipe]
#: Resources.resx loco:670e1cf615d80a27bc0eb3e9
#| msgid "Select files to wipe"
msgid "DialogTitleSelectFilesToWipe"
msgstr "Selecionar arquivos para apagar"

#. A title for a generic select folder picker, used for both encrypt and decrypt folder etc. [DialogTitleSelectFolder]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ea
#| msgid "Select folder"
msgid "DialogTitleSelectFolder"
msgstr "Selecionar pasta"

#. An error text displayed when an attempt is made to sign in twice with the same profile email. [DialogValidationAlreadySignedIn]
#: Resources.resx loco:670e1cf615d80a27bc0eb3eb
#| msgid ""
#| "You are already signed in. Look for the app behind another window, on "
#| "another screen, among minimized apps or in the system tray and show the "
#| "window from there."
msgid "DialogValidationAlreadySignedIn"
msgstr ""
"Você já está conectado. Procure o aplicativo atrás de outra janela, em outra "
"tela, entre os aplicativos minimizados ou na bandeja do sistema e exiba a "
"janela a partir daí."

#. An error text displayed when no password confirmation was entered. [DialogValidationConfirmPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ec
#| msgid "Please confirm the password again"
msgid "DialogValidationConfirmPassword"
msgstr "Por favor, confirme a senha novamente"

#. An error text displayed when validation of email format fails. [DialogValidationInvalidEmail]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ed
#| msgid "Please enter a valid email address"
msgid "DialogValidationInvalidEmail"
msgstr "Por favor, insira um endereço de email válido"

#. An error text displayed when no password is entered although required. [DialogValidationPasswordRequired]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ee
#| msgid "Please enter a password"
msgid "DialogValidationPasswordRequired"
msgstr "Por favor, insira uma senha"

#. An error message displayed in a dialog when the users enters the wrong password. [DialogValidationWrongPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb3ef
#| msgid "Wrong password!"
msgid "DialogValidationWrongPassword"
msgstr "Senha incorreta!"

#. An information message giving a hint that to change the configuration, you first need to remove the current configuration. [DialogYubiKeyChangeConfiguration]
#: Resources.resx loco:682308272f4e99990a0fc732
#| msgid ""
#| "To change the YubiKey configuration, you must first remove the existing "
#| "configuration."
msgid "DialogYubiKeyChangeConfiguration"
msgstr ""
"Para alterar a configuração da YubiKey, é necessário remover a configuração "
"existente primeiro."

#. An information message giving hints on how to change YubiKey defaults, and referring to help for more info where actual links etc are. [DialogYubiKeyDefaultChangeInfo]
#: Resources.resx loco:682308272f4e99990a0fc733
#| msgid ""
#| "To change the PIN, PUK, or Management Key, get the Yubico Authenticator "
#| "app and go to Certificates settings. For details, click the help icon."
msgid "DialogYubiKeyDefaultChangeInfo"
msgstr ""
"Para alterar o PIN, PUK ou a Management Key, obtenha o aplicativo Yubico "
"Authenticator e vá para as configurações de Certificados. Para mais detalhes,"
" clique no ícone de ajuda."

#. Dialog title for the YubiKey disabling setup dialog. [DialogYubiKeyDisable]
#: Resources.resx loco:670e1cf615d80a27bc0eb3f0
#| msgid "Do you want to remove the YubiKey configuration?"
msgid "DialogYubiKeyDisable"
msgstr "Você quer remover a configuração da YubiKey?"

#. Dialog title for the YubiKey enabling setup dialog. [DialogYubiKeyEnable]
#: Resources.resx loco:670e1cf615d80a27bc0eb3f1
#| msgid "Do you want to enable this YubiKey for signing in?"
msgid "DialogYubiKeyEnable"
msgstr "Você quer habilitar esta YubiKey para login?"

#. Error message when enabling fails, typically because there are no slots. [DialogYubiKeyEnabledFailed]
#: Resources.resx loco:670e1cf615d80a27bc0eb3f2
#| msgid ""
#| "It is not possible to use this YubiKey. There may not be any slots "
#| "available."
msgid "DialogYubiKeyEnabledFailed"
msgstr "Não é possível usar esta YubiKey. Pode não haver slots disponíveis."

#. A dialog title used when asking for PIV management key authentication [DialogYubiKeyEnterKeyTitle]
#: Resources.resx loco:670e1cf615d80a27bc0eb3f3
#| msgid "Please enter YubiKey PIV hex management key:"
msgid "DialogYubiKeyEnterKeyTitle"
msgstr ""
"Por favor, insira a chave de gerenciamento hexadecimal do PIV da YubiKey:"

#. A dialog title used when asking for the PIN [DialogYubiKeyEnterPinTitle]
#: Resources.resx loco:670e1cf615d80a27bc0eb3f4
#| msgid "Please enter YubiKey PIV PIN:"
msgid "DialogYubiKeyEnterPinTitle"
msgstr "Por favor, insira o PIN do PIV da YubiKey:"

#. Dialog title displayed when we're checking for a YubiKey during setup [DialogYubiKeyLooking]
#: Resources.resx loco:670e1cf615d80a27bc0eb3f5
#| msgid "Waiting for YubiKey..."
msgid "DialogYubiKeyLooking"
