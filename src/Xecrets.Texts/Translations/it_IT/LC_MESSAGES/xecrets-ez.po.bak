msgstr "Il segreto"

#. A text fragment appearing in the about window, informing that the license is not valid for Ez. [LicenseNotValidForProductBlurb]
#: Resources.resx loco:670e1cf615d80a27bc0eb411
#, icu-format
#| msgid ""
#| "License '{product}' for {licensee} is not valid for this software. Free "
#| "version, some features unavailable.\\nSee https://www.axantum.com/ ."
msgid "LicenseNotValidForProductBlurb"
msgstr ""
"La licenza '{product}' per {licensee} non è valida per questo software. "
"Versione gratuita, alcune funzionalità non disponibili. Vedi https://www."
"axantum.com/ ."

#. A text fragment appearing in the about window, informing that there is a currently valid license. [LicensedBlurb]
#: Resources.resx loco:670e1cf615d80a27bc0eb412
#, icu-format
#| msgid "License for {licensee} valid to {expiration}, thank you!"
msgid "LicensedBlurb"
msgstr "Licenza per {licensee} valida fino al {expiration}, grazie!"

#. A text fragment appearing in the about window, informing that there is a previously valid license, now expired. [LicensedExpiredBlurb]
#: Resources.resx loco:670e1cf615d80a27bc0eb413
#, icu-format
#| msgid ""
#| "License for {licensee} expired at {expiration}.\\nFree version, some "
#| "features unavailable.\\nSee https://www.axantum.com/ ."
msgid "LicensedExpiredBlurb"
msgstr ""
"La licenza per {licensee} è scaduta il {expiration}.\\nVersione gratuita, "
"alcune funzionalità non disponibili.\\nVedi https://www.axantum.com/ ."

