#: Resources.resx loco:68396d06ff6b3f753f0e72dc
#| msgid "Required shares"
msgid "PromptRequiredShares"
msgstr "Parti richieste"

#. Prompt for the total number of shares. [PromptTotalShares]
#: Resources.resx loco:68396d06ff6b3f753f0e72dd
#| msgid "Total shares"
msgid "PromptTotalShares"
msgstr "Totale parti"

#. Radio button text to share any arbitrary secret. [SelectShareAny]
#: Resources.resx loco:68396d06ff6b3f753f0e72de
#| msgid "Share any secret"
msgid "SelectShareAny"
msgstr "Condividi qualsiasi segreto"

#. Radio button text to share the sign in password. [SelectShareSignIn]
#: Resources.resx loco:68396d06ff6b3f753f0e72df
#| msgid "Share sign in password"
msgid "SelectShareSignIn"
msgstr "Condividi la password di accesso"

#. A menu entry or label to select a dark visual theme. [ThemeDark]
#: Resources.resx loco:670e1cf615d80a27bc0eb43e
#| msgid "_Dark"
msgid "ThemeDark"
msgstr "_Scuro"

#. A menu entry or label to select a light visual theme. [ThemeLight]
#: Resources.resx loco:670e1cf615d80a27bc0eb43f
#| msgid "_Light"
msgid "ThemeLight"
msgstr "_Chiaro"

#. A menu entry or lablel to select the visual theme to match the system theme. [ThemeSystem]
#: Resources.resx loco:670e1cf615d80a27bc0eb440
#| msgid "_System"
msgid "ThemeSystem"
msgstr "_Sistema"

#. An additional prompt informing that more information is available with a click. It may be added to help button and other tool tips at the end as a last sentence. [TipMoreHelp]
#: Resources.resx loco:670e1cf615d80a27bc0eb441
#| msgid "Click for more information..."
msgid "TipMoreHelp"
msgstr "Clicca per maggiori informazioni..."

#. Tooltip for the Add Password dialog, explaining a litte more. [ToolTipAddPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb442
#| msgid ""
#| "Adding a password is only for decryption, when you receive files from "
#| "someone else or you have used another password previously. It does not "
#| "affect encryption."
msgid "ToolTipAddPassword"
msgstr ""
"Aggiungere una password è solo per la decrittazione, quando ricevi file da "
"qualcun altro o hai usato un'altra password in precedenza. Non influisce "
"sulla crittografia."

#. Tooltip for the clear passwords dialog. [ToolTipClearPasswords]
#: Resources.resx loco:670e1cf615d80a27bc0eb443
#| msgid ""
#| "Clear decryption passwords saved in settings. You can always add them "
#| "back again."
msgid "ToolTipClearPasswords"
msgstr ""
"Cancella le password di decrittazione salvate nelle impostazioni. Puoi "
"sempre aggiungerle di nuovo."

#. Help tool tip for the combine shares dialog. It should be followed by a "Click for more info...." prompt, leading to a help page. [ToolTipCombineShares]
#: Resources.resx loco:68396d06ff6b3f753f0e72e0
#| msgid ""
#| "Enter the required number of shares to combine them and view the secret."
msgid "ToolTipCombineShares"
msgstr ""
"Inserisci il numero richiesto di parti per combinarle e visualizzare il "
"segreto."

#. A tool tip shown when hovering over the copy button in the suggest password dialog. [ToolTipCopySuggested]
#: Resources.resx loco:670e1cf615d80a27bc0eb444
#| msgid "Copy the suggested password and close the dialog."
msgid "ToolTipCopySuggested"
msgstr "Copia la password suggerita e chiudi la finestra."

#. Help tool tip for the create shares dialog. It should be followed by a "Click for more info.." prompt, leading to a help page. [ToolTipCreateShares]
#: Resources.resx loco:68396d06ff6b3f753f0e72e1
#| msgid ""
#| "Split a secret into shares, specifying how many shares and how many are "
#| "required to recover the secret."
msgid "ToolTipCreateShares"
msgstr ""
"Dividi un segreto in parti, specificando quante generarne e quante sono "
"necessarie per recuperarlo."

#. A tool tip text explaining the function of the scale factor decrease button. [ToolTipDecreaseScaleFactor]
#: Resources.resx loco:670e1cf615d80a27bc0eb445
#| msgid "Make text and window smaller."
msgid "ToolTipDecreaseScaleFactor"
msgstr "Riduci le dimensioni del testo e della finestra."

#. A tool tip text explaining that entering an email is only a convient format to name or tag a user, it's not used to send emails. [ToolTipEmail]
#: Resources.resx loco:670e1cf615d80a27bc0eb446
#| msgid ""
#| "Not used for sending emails. It's a name to identify you in the software "
#| "and for sharing with others."
msgid "ToolTipEmail"
msgstr ""
"Non utilizzato per l'invio di email. È un nome per identificarti nel "
"software e per condividerlo con gli altri."

#. A tool tip for the emergency reset, warning that old files still need the old password. [ToolTipEmergencyReset]
#: Resources.resx loco:670e1cf615d80a27bc0eb447
#| msgid ""
#| "Set a new master password. Warning! The old password is still needed to "
#| "decrypt previously encrypted files!"
msgid "ToolTipEmergencyReset"
msgstr ""
"Imposta una nuova password principale. Avviso! La vecchia password è ancora "
"necessaria per decriptare i file precedentemente criptati!"

#. A tooltip for the text encryption feature [ToolTipEncryptDecryptText]
#: Resources.resx loco:670e1cf615d80a27bc0eb448
#| msgid ""
#| "Write or copy/paste text to encrypt or decrypt. The password will be used "
#| "to encrypt or decrypt the text, and should be shared in a separate "
#| "channel between the sender and recipient. Always include the BEGIN header "
#| "and the END footer with the encrypted text."
msgid "ToolTipEncryptDecryptText"
msgstr ""
"Scrivi o copia/incolla il testo da criptare o decriptare. La password verrà "
"utilizzata per criptare o decriptare il testo e dovrà essere condivisa "
"tramite un canale separato tra il mittente e il destinatario. Includi sempre "
"l'intestazione \"BEGIN\" e il piè di pagina \"END\" con il testo criptato."

#. A tool tip for the get license dialog which using the user name and the last 4 digits, will open a browser page with the license if found. [ToolTipGetLicense]
#: Resources.resx loco:670e1cf615d80a27bc0eb449
#| msgid ""
#| "When your purchased license has expired, or you are using a new device, "
#| "you must fetch a license from the server. Provide the information here "
#| "and follow the instructions."
msgid "ToolTipGetLicense"
msgstr ""
"Quando la tua licenza acquistata è scaduta o stai utilizzando un nuovo "
"dispositivo, devi recuperare una licenza dal server. Fornisci le "
"informazioni qui e segui le istruzioni."

#. An additional tooltip part, that explains that if no card was entered, getting the license this way won't work so easily. [ToolTipGetLicenseNoCard]
#: Resources.resx loco:670e1cf615d80a27bc0eb44a
#| msgid "Leave the last 4 digits empty if you didn't use a card."
msgid "ToolTipGetLicenseNoCard"
msgstr "Lascia vuote le ultime 4 cifre se non hai usato una carta."

#. A tooltip for the hide password buton in password dialogs [ToolTipHidePassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb44b
#| msgid "Hide password."
msgid "ToolTipHidePassword"
msgstr "Nascondi password."

#. A tooltip describing that a clicking a button hides the menus and buttons for premium when in free version. [ToolTipHidePremium]
#: Resources.resx loco:670e1cf615d80a27bc0eb44c
#| msgid "Hide premium features unavailable in the free version."
msgid "ToolTipHidePremium"
msgstr ""
"Nascondi le funzionalità Premium non disponibili nella versione gratuita."

#. A tool tip text explaining the function of the scale factor increase button. [ToolTipIncreaseScaleFactor]
#: Resources.resx loco:670e1cf615d80a27bc0eb44d
#| msgid "Make text and window bigger."
msgid "ToolTipIncreaseScaleFactor"
msgstr "Ingrandisci il testo e la finestra."

#. A tool tip text explaining briefly about the master password, that it should be strong and kept safe. [ToolTipMasterPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb44e
#| msgid ""
#| "Your master password. Make it strong, write it down and keep it safe."
msgid "ToolTipMasterPassword"
msgstr ""
"La tua password principale. Rendila forte, scrivila e conservala al sicuro."

#. A tooltip for the show password button in password dialogs [ToolTipShowPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb44f
#| msgid "Show password."
msgid "ToolTipShowPassword"
msgstr "Mostra password."

#. A tooltip describing that clicking a button shows the menus and buttons for premium even when in free version. [ToolTipShowPremium]
#: Resources.resx loco:670e1cf615d80a27bc0eb450
#| msgid "Show all premium features."
msgid "ToolTipShowPremium"
msgstr "Mostra tutte le funzionalità Premium"

#. Tooltip for the sign in dialog, explaining the reason. [ToolTipSignIn]
#: Resources.resx loco:670e1cf615d80a27bc0eb451
#| msgid ""
#| "Signing in ensures you are using the correct password for encryption, and "
#| "that you don't need to retype the password each time. This is the master "
#| "password for all encryption. The sign in is only local to the app."
msgid "ToolTipSignIn"
msgstr ""
"Accedere garantisce che stai usando la password corretta per la crittografia "
"e che non è necessario digitare nuovamente la password ogni volta. Questa è "
"la password principale per tutta la crittografia. L'accesso è solo locale "
"all'app."

#. A tool tip for the suggest a password for create new user or change password. [ToolTipSuggestMasterPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb452
#| msgid "Suggest a password."
msgid "ToolTipSuggestMasterPassword"
msgstr "Suggerisci una password."

#. Tooltip for the view shares dialog. Should be followed by a "Click for more info..." prompt, leading to the help page. [ToolTipViewShares]
#: Resources.resx loco:68396d06ff6b3f753f0e72e2
#| msgid ""
#| "View previously created shares, and send or save them to different places."
msgid "ToolTipViewShares"
msgstr ""
"Visualizza le parti create in precedenza e inviale o salvale in posizioni "
"diverse."

#. The tool tip for the help button in the YubiKey setup dialog. [ToolTipYubiKeySetup]
#: Resources.resx loco:670e1cf615d80a27bc0eb453
#| msgid ""
#| "Enable or disable the use of a YubiKey for sign in. Use the Yubico "
#| "Authenticator or other utilities to reset, change and inspect the YubiKey "
#| "PIV configuration in more detail."
msgid "ToolTipYubiKeySetup"
msgstr ""
"Abilita o disabilita l'uso di un YubiKey per l'accesso. Utilizza Yubico "
"Authenticator o altri strumenti per reimpostare, modificare e ispezionare la "
"configurazione PIV del YubiKey in modo più dettagliato."

#. A text fragment appearing in the about window, informing that there is no license. [UnlicensedBlurb]
#: Resources.resx loco:670e1cf615d80a27bc0eb454
#| msgid ""
#| "Free version, some features are unavailable.\n"
#| "\n"
#| "Please buy a license. See https://www.axantum.com/ ."
msgid "UnlicensedBlurb"
msgstr ""
"Versione gratuita, alcune funzionalità non sono disponibili.\n"
"\n"
"Per favore acquista una licenza. Visita https://www.axantum.com/ ."

#. The information text in the message box displayed when it's time to check for updates. [UpdateCheckInformation]
#: Resources.resx loco:670e1cf615d80a27bc0eb455
#| msgid "Would you like to check if there's an update available?"
msgid "UpdateCheckInformation"
msgstr "Vuoi controllare se è disponibile un aggiornamento?"

#. The title of the message box displayed when it's time to check for updates. [UpdateCheckTitle]
#: Resources.resx loco:670e1cf615d80a27bc0eb456
#| msgid "Update check"
msgid "UpdateCheckTitle"
msgstr "Controllo aggiornamenti"

#. The explanatory text in the view shares dialog. {0} refers to the threshold, or number of shares required. [ViewSharesDescriptionFormat]
#: Resources.resx loco:68396d06ff6b3f753f0e72e3
#, icu-format
#| msgid ""
#| "Save or distribute these shares to different people or places. At least "
#| "{0} shares are required to recover the secret."
msgid "ViewSharesDescriptionFormat"
msgstr ""
"Salva o distribuisci queste parti a persone o luoghi diversi. Sono "
"necessarie almeno {0} parti per recuperare il segreto."

#. The text used as watermark (slightly transparent grey) in a password confirmation entry text box, i.e. "Confirm Password". [WatermarkConfirmPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb457
#| msgid "Confirm password"
msgid "WatermarkConfirmPassword"
msgstr "Conferma password"

#. The text used as watermark (slightly transparent grey) in a current password entry text box when changing password, i.e. "Current Password". [WatermarkCurrentPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb458
#| msgid "Current password"
msgid "WatermarkCurrentPassword"
msgstr "Password attuale"

#. The text used as watermark (slightly transparent grey) in a email entry text box, i.e. "Email". [WatermarkEmail]
#: Resources.resx loco:670e1cf615d80a27bc0eb459
#| msgid "Email"
msgid "WatermarkEmail"
msgstr "Email"

#. The watermark prompt for the last 4 digits to enter. [WatermarkLast4]
#: Resources.resx loco:670e1cf615d80a27bc0eb45a
#| msgid "4 digits"
msgid "WatermarkLast4"
msgstr "4 cifre"

#. The text used as watermark (slightly transparent grey) in a new password entry text box when changing password, i.e. "New Password". [WatermarkNewPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb45b
#| msgid "New password"
msgid "WatermarkNewPassword"
msgstr "Nuova password"

#. The text used as watermark (slightly transparent grey) in a password entry text box, i.e. "Master Password". [WatermarkPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb45c
#| msgid "Password"
msgid "WatermarkPassword"
msgstr "Password"

#. Watermark text for password or secret entry to share. [WatermarkPasswordSecret]
#: Resources.resx loco:68396d06ff6b3f753f0e72e4
#| msgid "Enter any password or secret…"
msgid "WatermarkPasswordSecret"
msgstr "Inserisci qualsiasi password o segreto…"

#. A watermark for entering sharing passwords [WatermarkPasswordShare]
#: Resources.resx loco:670e1cf615d80a27bc0eb45d
#| msgid "Password to share"
msgid "WatermarkPasswordShare"
msgstr "Password da condividere"

#. A warning text, stating that one or more files are zero length, asking if the user is sure. The text should be followed by ConfirmationQuestion. It's followed by a list of the files that are detected as zero length. [ZeroLengthWarning]
#: Resources.resx loco:68224b6ec1aa19265801d812
#| msgid "One or more selected files are empty. They might be damaged."
msgid "ZeroLengthWarning"
msgstr "Uno o più file selezionati sono vuoti. Potrebbero essere danneggiati."

#. Status text for number of files currently open, {0} is the number of files. Singular version|Plural version [ZzCommandBarContentFilesOpenFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb45e
#, icu-format
#| msgid "No open files|One open file...|{0} Open files..."
msgid "ZzCommandBarContentFilesOpenFormat"
msgstr "Nessun file aperto|Un file aperto...|{0} file aperti..."

#. A heading in the sign in window, {0} is the program name, i.e. "Xecrets Ez". [ZzHeadingSignInFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb45f
#, icu-format
#| msgid "Sign in to {0}"
msgid "ZzHeadingSignInFormat"
msgstr "Accedi a {0}"

#. CLI API version label in about box, {0} is the tools display name, followed by the version, i.e. "Command Line Tools API Version:" 1.2 [ZzLabelCliToolApiVersionFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb460
#, icu-format
#| msgid "{0} API version:"
msgid "ZzLabelCliToolApiVersionFormat"
msgstr "Versione API {0}:"

#. CLI information label in about box, {0} is the tools display name, followed by some information, i.e. "Command Line Tools Information:" ...Splash from CLI. [ZzLabelCliToolInformationFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb461
#, icu-format
#| msgid "{0} information:"
msgid "ZzLabelCliToolInformationFormat"
msgstr "{0} Informazioni:"

#. CLI path label in about box, {0} is the tools display name, followed by a path, i.e. "Command Line Tools Path:" ... [ZzLabelCliToolPathFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb462
#, icu-format
#| msgid "{0} path:"
msgid "ZzLabelCliToolPathFormat"
msgstr "{0} Percorso:"

#. The SDK API Version label in about box, {0} is the SDK API display name, i.e. "SDK API Version:" 1.3. [ZzLabelSdkApiVersionFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb463
#, icu-format
#| msgid "{0} version:"
msgid "ZzLabelSdkApiVersionFormat"
msgstr "{0} Versione:"

#. Window title for About dialog. {0} is the full program version name, i.e. "Xecrets Ez 2.1.1337.0". [ZzTitleAboutFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb464
#, icu-format
#| msgid "About {0}"
msgid "ZzTitleAboutFormat"
msgstr "Info su {0}"

#. Program version window title format string, {0} is the actual version, i.e. "2.1.1337.0", {1} is the program name, i.e. "Xecrets Ez", {2} is the email of the signed in user, or empty. [ZzTitleProgramVersionNameFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb465
#, icu-format
#| msgid "{1} {0} {2}"
msgid "ZzTitleProgramVersionNameFormat"
msgstr "{1} {0} {2}"
