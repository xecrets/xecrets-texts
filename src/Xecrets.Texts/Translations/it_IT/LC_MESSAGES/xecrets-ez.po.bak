#. Error message when decryption fails due to broken data. [MessageFileFormatError]
#: Resources.resx loco:670e1cf615d80a27bc0eb437
#| msgid "The encrypted data is not correctly formatted."
msgid "MessageFileFormatError"
msgstr "I dati criptati non sono formattati correttamente."

#. A message when decrypting a file that does not start with the magic guid. [MessageNotEncrypted]
#: Resources.resx loco:680b8a0748ff58b5370e39d2
#| msgid ""
#| "The initial 16 bytes are wrong, it is probably some other kind of data or "
#| "severely damaged."
msgid "MessageNotEncrypted"
msgstr ""
"I primi 16 byte sono errati. Si tratta probabilmente di un altro tipo di "
"dato oppure è gravemente danneggiato."

#. Error message when an improperly formatted license string is attempted to be used. [MessageTextBadLicenseString]
#: Resources.resx loco:6745a304c4fd5b3bae0bcef8
#| msgid "The license string is not in the correct format."
msgid "MessageTextBadLicenseString"
msgstr "La stringa della licenza non è nel formato corretto."

#. A warning when the number of files requested for an operation is higher than a threshold. {0} will be filled with the exact number of files. [MessageTextConfirmManyFilesFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb438
#, icu-format
#| msgid "That's {0} files!"
msgid "MessageTextConfirmManyFilesFormat"
msgstr "Sono {0} file!"

#. A confirmation message prompt when pasting a directory. [MessageTextConfirmPasteDirectory]
#: Resources.resx loco:67572ea92257d74f5c003653
#| msgid "That includes a directory."
msgid "MessageTextConfirmPasteDirectory"
msgstr "Questo include una directory."

#. A text asking a yes/no response confirmation for a dangerous irreversible operation, i.e. File Wipe. [MessageTextConfirmWipe]
#: Resources.resx loco:670e1cf615d80a27bc0eb439
#| msgid "This operation cannot be undone."
msgid "MessageTextConfirmWipe"
msgstr "Questa operazione non può essere annullata."

#. A short text shown as a hyperlink in the sign in dialog. [MessageTextForgotPassword]
#: Resources.resx loco:670e1cf615d80a27bc0eb43a
#| msgid "Forgot your password?"
msgid "MessageTextForgotPassword"
msgstr "Hai dimenticato la password?"

#. A message when decrypting a file or text with exactly zero bytes. It is followed by one or more file names. [MessageZeroLength]
#: Resources.resx loco:680b8a0748ff58b5370e39d3
#| msgid "The data is damaged, the length is zero bytes."
msgid "MessageZeroLength"
msgstr "Il dato è danneggiato, la dimensione è pari a zero byte."

#. A warning message displayed when an operation includes both encrypted an unencrypted files. [MixedFilesWarning]
#: Resources.resx loco:678bf611545b8ded0e016fc2
#| msgid ""
#| "Both encrypted and plain files are included. The plain files will be "
#| "encrypted, and the already encrypted will be unchanged."
msgid "MixedFilesWarning"
msgstr ""
"Sono inclusi sia file crittografati che non crittografati. I file non "
"crittografati saranno crittografati, mentre quelli già crittografati "
"rimarranno invariati."

#. A warning/info message stating that an attempt to close all files did not succeed completely and at least one file remain open. [OpenFilesRemainMessage]
#: Resources.resx loco:670e1cf615d80a27bc0eb43b
#| msgid "File(s) couldn't be closed and remain open!"
msgid "OpenFilesRemainMessage"
msgstr "I file non possono essere chiusi e rimangono aperti!"

#. A message displayed when a multi-file operation was canceled, {0} is the full name of the file that was interrupted. [OperationCanceledFormat]
#: Resources.resx loco:670e1cf615d80a27bc0eb43c
#, icu-format
#| msgid "Operation was canceled during processing of '{0}'. Check and verify!"
msgid "OperationCanceledFormat"
msgstr ""
"L'operazione è stata annullata durante l'elaborazione di '{0}'. Controlla e "
"verifica!"

#. A text shown as a placeholder when loading things takes time in a window, i.e. "Loading...". [PlaceholderLoading]
#: Resources.resx loco:670e1cf615d80a27bc0eb43d
#| msgid "Loading..."
msgid "PlaceholderLoading"
msgstr "Caricamento in corso..."

